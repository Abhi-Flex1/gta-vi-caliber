[gd_scene load_steps=11 format=3]

; Los Angeles via the M3 district streamer: districts page in and out around the
; player from the world manifest, so the map scales to all of LA without loading
; every tile at once. Player starts in downtown; drive/walk toward Hollywood and
; it streams in at its real 9.5 km offset.

[ext_resource type="PackedScene" path="res://scenes/player/player.tscn" id="1_player"]
[ext_resource type="PackedScene" path="res://scenes/ui/debug_hud.tscn" id="2_hud"]
[ext_resource type="Script" path="res://scripts/world/district_streamer.gd" id="3_streamer"]
[ext_resource type="Script" path="res://scripts/world/weather_controller.gd" id="5_weather"]
[ext_resource type="Shader" path="res://assets/shaders/sky.gdshader" id="6_sky"]
[ext_resource type="Script" path="res://scripts/world/sky_controller.gd" id="7_daynight"]
[ext_resource type="Script" path="res://scripts/ui/streaming_hud.gd" id="9_shud"]

; Physical atmosphere sky (Rayleigh/Mie scattering, sun disk, procedural clouds,
; stars/moon at night), driven live by SkyController — same pipeline downtown
; uses, so the streamed gameplay world gets golden hour + clouds + night sky.
[sub_resource type="ShaderMaterial" id="sky_mat"]
shader = ExtResource("6_sky")
shader_parameter/sun_direction = Vector3(0.41, 0.81, -0.42)
shader_parameter/sun_energy = 1.0
shader_parameter/moon_direction = Vector3(-0.41, -0.81, 0.42)
shader_parameter/night_amount = 0.0
shader_parameter/rayleigh_strength = 1.0
shader_parameter/mie_strength = 1.0
shader_parameter/mie_eccentricity = 0.76
shader_parameter/sun_intensity = 22.0
shader_parameter/exposure = 1.1
shader_parameter/sun_angular_size = 1.2
shader_parameter/sun_disk_color = Color(1, 0.95, 0.86, 1)
shader_parameter/cloud_coverage = 0.46
shader_parameter/cloud_density = 1.3
shader_parameter/cloud_height = 1200.0
shader_parameter/cloud_scale = 0.00055
shader_parameter/cloud_wind = Vector2(0.012, 0.006)
shader_parameter/cloud_base_color = Color(0.62, 0.66, 0.72, 1)
shader_parameter/cloud_lit_color = Color(1, 0.98, 0.94, 1)
shader_parameter/star_density = 0.16
shader_parameter/night_zenith = Color(0.012, 0.016, 0.035, 1)
shader_parameter/moon_color = Color(0.85, 0.88, 0.95, 1)

[sub_resource type="Sky" id="sky"]
sky_material = SubResource("sky_mat")
radiance_size = 4

; Premium streamed-world environment (CinematicEnvironment.enhance, no SDFGI:
; SDFGI flickers as districts page in). Sky-sourced ambient + SSR so glass
; curtain-walls mirror the sky/street; SSAO/SSIL contact + bounce; ACES grade.
[sub_resource type="Environment" id="env"]
background_mode = 2
sky = SubResource("sky")
ambient_light_source = 3
reflected_light_source = 2
tonemap_mode = 3
tonemap_white = 6.0
ssao_enabled = true
ssao_radius = 3.0
ssao_intensity = 2.2
ssao_power = 1.5
ssil_enabled = true
ssr_enabled = true
ssr_max_steps = 48
ssr_fade_in = 0.15
ssr_fade_out = 2.0
ssr_depth_tolerance = 0.2
glow_enabled = true
glow_intensity = 0.7
glow_bloom = 0.12
glow_hdr_threshold = 1.1
fog_enabled = true
fog_light_color = Color(0.74, 0.79, 0.86, 1)
fog_density = 0.0008
fog_sky_affect = 0.2
fog_aerial_perspective = 0.5
volumetric_fog_enabled = true
volumetric_fog_density = 0.002
volumetric_fog_albedo = Color(0.82, 0.86, 0.92, 1)
adjustment_enabled = true
adjustment_contrast = 1.08
adjustment_saturation = 1.14
adjustment_brightness = 1.01

